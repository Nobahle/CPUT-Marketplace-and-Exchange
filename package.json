{
  "name": "cput-marketplace",
  "version": "1.0.0",
  "type": "module",
  "description": "A modern marketplace platform for CPUT students",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "setup-db": "mysql -u root -p < server/db/schema.sql",
    "install-server": "cd server && npm install"
  },
  "keywords": [
    "marketplace",
    "cput",
    "students",
    "exchange"
  ],
  "author": "CPUT Marketplace Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "firebase-admin": "^12.1.0",
    "multer": "^1.4.4",
    "mysql2": "^3.9.7",
    "socket.io": "^4.7.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
